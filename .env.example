# ============================================================
# AutoScore Hub — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your values.
# In production (Vercel), set these in Project Settings → Environment Variables.

# ============================================================
# Twitter API (for the tweet-draft / tweet-post scripts)
# ============================================================
# Get these from https://developer.x.com/en/portal/dashboard
# Your app must have "Read and Write" permissions.

# App credentials (Consumer Key + Secret)
TWITTER_CONSUMER_KEY=your_consumer_key_here
TWITTER_CONSUMER_SECRET=your_consumer_secret_here

# User credentials (Access Token + Secret) — needed to POST tweets
# Generate these in the Twitter Developer Portal under
# "Keys and tokens" → "Authentication Tokens" → "Access Token and Secret"
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ============================================================
# Site URL (used in tweet copy + OG metadata)
# ============================================================
# After deploying to Vercel, set this to your production URL.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
